# ============================================================
# 小暖 - 环境变量配置
# 复制此文件为 .env 并填入你的真实配置
# ============================================================

# --- OpenAI API（兼容 DeepSeek / 通义千问等）---
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# --- 伴侣设定 ---
COMPANION_NAME=小暖
# 系统提示词基础模板在 config.py 中
# 启动时会自动从 data/ 目录加载风格数据注入到提示词中

# --- 会话 ---
MAX_CONTEXT_MESSAGES=30
SESSION_EXPIRE_HOURS=72
MAX_TOKENS=800
TEMPERATURE=0.85

# --- 微信公众号 ---
# 小暖aini 公众号后台 → 设置与开发 → 基本配置
WECHAT_TOKEN=your_wechat_token_here
WECHAT_ENCODING_AES_KEY=
WECHAT_APP_ID=

# --- 服务 ---
HOST=0.0.0.0
PORT=8000
