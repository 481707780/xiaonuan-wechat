{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "nixpacksConfig": "nixpacks.toml",
    "watchPatterns": [
      "backend/**/*.py",
      "requirements.txt",
      "run.py",
      "railway.json",
      "nixpacks.toml"
    ]
  },
  "deploy": {
    "startCommand": "python run.py",
    "healthcheckPath": "/health",
    "restartPolicyType": "ALWAYS",
    "restartPolicyMaxRetries": 3,
    "numReplicas": 1
  }
}
